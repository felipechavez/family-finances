{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "#shared/types": ["./shared/types/finanzas"],
      "~/*": ["./app/*"],
      "~~/*": ["./*"]
    }
  }
}
